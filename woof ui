        addBtn.Size = dn(0, 18, 0, 18)
        addBtn.Font = Enum.Font.Gotham
        addBtn.Text = "+"
        addBtn.TextColor3 = dp(255, 255, 255)
        addBtn.TextSize = 18.000
        
