    function tabMethods:Slider(config)
        local sliderBtn = dq("TextButton")
        local sliderCorner = dq("UICorner")
        local sliderBar = dq("Frame")
        local barCorner = dq("UICorner")
        local sliderPart = dq("Frame")
        local partCorner = dq("UICorner")
