        local valueCorner = dq("UICorner")
        local addBtn = dq("TextButton")
        local minusBtn = dq("TextButton")
        
        local flagName = config.Flag or config.Title
        local min = config.Min or 0
        local max = config.Max or 100
        local default = config.Default or min
        local callback = config.Callback or dr
        
        library.flags[flagName] = {
            State = default,
            SetValue = function(self, value)
                if value then
                    value = tonumber(value)
                    if value then
                        value = math.clamp(value, min, max)
                        library.flags[flagName].State = value
                        valueBox.Text = tostring(math.floor(value))
                        local percent = (value - min) / (max - min)
                        sliderPart.Size = dn(percent, 0, 1, 0)
                        callback(value)
                    end
                end
            end
        }
        
        sliderBtn.Name = "SliderModule"
        sliderBtn.Parent = tabFrame
        sliderBtn.BackgroundColor3 = dp(52, 62, 72)
        sliderBtn.BorderSizePixel = 0
