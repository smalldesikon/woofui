-- 切换标签页
function WoofUIModule:SwitchTab(tab)
    if currentTab and currentTab[2] and currentTab[2].Glow then
        dv:Tween({Transparency = 1}, currentTab[2].Glow):Play()
    end
    if tab and tab[2] and tab[2].Glow then
        dv:Tween({Transparency = 0}, tab[2].Glow):Play()
    end
    if currentTab and currentTab[1] then
        currentTab[1].Visible = false
    end
    if tab and tab[1] then
        tab[1].Visible = true
    end
    currentTab = tab
end

