        library.flags[flagName] = { 
            State = options[1] or "",
            SetOptions = function(self, newOptions)
                options = newOptions
                -- 清空现有选项
                for _, child in ipairs(dropdownBottom:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                -- 添加新选项
