        dropdownBtn.TextXAlignment = Enum.TextXAlignment.Left
        
        dropdownCorner.CornerRadius = dm(0, 6)
        dropdownCorner.Name = "DropdownModuleCorner"
        dropdownCorner.Parent = dropdownBtn
        
        dropdownText.Name = "DropdownText"
        dropdownText.Parent = dropdownBtn
        dropdownText.BackgroundColor3 = dp(255, 255, 255)
        dropdownText.BackgroundTransparency = 1.000
        dropdownText.Position = dn(0.025641026, 0, 0, 0)
        dropdownText.Size = dn(0, 192, 0, 28)
        dropdownText.Font = Enum.Font.GothamSemibold
        dropdownText.PlaceholderText = config.Title
        dropdownText.PlaceholderColor3 = dp(255, 255, 255)
        dropdownText.TextColor3 = dp(255, 255, 255)
        dropdownText.TextSize = 14.000
        dropdownText.TextXAlignment = Enum.TextXAlignment.Left
        dropdownText.Text = ""
        
        openBtn.Name = "OpenDropdown"
        openBtn.Parent = dropdownBtn
        openBtn.BackgroundColor3 = dp(255, 255, 255)
        openBtn.BackgroundTransparency = 1.000
        openBtn.BorderSizePixel = 0
        openBtn.Position = dn(0.907051265, 0, 0.178571433, 0)
        openBtn.Size = dn(0, 18, 0, 18)
        openBtn.Font = Enum.Font.Gotham
        openBtn.Text = "+"
        openBtn.TextColor3 = dp(255, 255, 255)
        openBtn.TextSize = 22.000
        
        dropdownBottom.Name = "DropdownBottom"
        dropdownBottom.Parent = tabFrame
        dropdownBottom.BackgroundColor3 = dp(52, 62, 72)
        dropdownBottom.BorderSizePixel = 0
        dropdownBottom.ClipsDescendants = true
        dropdownBottom.Size = dn(0, 312, 0, 0)
        dropdownBottom.AutoButtonColor = false
        dropdownBottom.Visible = false
        
        bottomCorner.CornerRadius = dm(0, 6)
        bottomCorner.Name = "DropdownBottomCorner"
        bottomCorner.Parent = dropdownBottom
        
        bottomLayout.Name = "DropdownBottomLayout"
        bottomLayout.Parent = dropdownBottom
        bottomLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        bottomLayout.SortOrder = Enum.SortOrder.LayoutOrder
        bottomLayout.Padding = dm(0, 6)
        
        bottomPadding.Name = "DropdownBottomPadding"
        bottomPadding.Parent = dropdownBottom
        bottomPadding.PaddingTop = dm(0, 6)
        
        -- 添加选项
        for _, option in ipairs(options) do
            library.flags[flagName]:AddOption(option)
        end
        
        -- 自动调整大小
        local isOpen = false
        bottomLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            if isOpen then
                dv:Tween({Size = dn(0, 312, 0, bottomLayout.AbsoluteContentSize.Y + 12)}, dropdownBottom, 0.1):Play()
            end
        end)
        
        local function toggleDropdown()
            isOpen = not isOpen
            if isOpen then
                dropdownBottom.Visible = true
                openBtn.Text = "-"
                dv:Tween({Size = dn(0, 312, 0, bottomLayout.AbsoluteContentSize.Y + 12)}, dropdownBottom, 0.2):Play()
            else
                openBtn.Text = "+"
                dv:Tween({Size = dn(0, 312, 0, 0)}, dropdownBottom, 0.2):Play()
                wait(0.2)
                dropdownBottom.Visible = false
            end
        end
        
        openBtn.MouseButton1Click:Connect(toggleDropdown)
        
        addButtonFeedback(dropdownBtn, dp(52, 62, 72))
        addButtonFeedback(openBtn, dp(255, 255, 255))
        
        return {
            SetOptions = function(newOptions)
                library.flags[flagName]:SetOptions(newOptions)
            end,
            AddOption = function(option)
                library.flags[flagName]:AddOption(option)
            end,
            RemoveOption = function(option)
                library.flags[flagName]:RemoveOption(option)
            end,
            GetValue = function()
                return library.flags[flagName].State
            end
        }
    end

    -- 存储标签页
    tabs[tabName] = tabMethods
    library.tabs[tabName] = tabMethods
    
    return tabMethods
end

-- 外部接口
function WoofUIModule:CreateWindow(name)
    if not dD then
        self:Initialize()
    end
    
    if name then
        dE:FindFirstChild("TextLabel").Text = "  " .. name
    end
    
    return {
        CreateTab = function(tabName)
            return WoofUIModule:CreateTab(tabName)
        end,
        Toggle = function(state)
            dD.Enabled = not dD.Enabled
        end,
        Destroy = function()
            if dD then
                dD:Destroy()
                dD = nil
            end
        end
    }
end

-- 设置UI名称
function WoofUIModule:SetName(name)
    if dD and dE then
        local label = dE:FindFirstChild("TextLabel")
        if label then
            label.Text = "  " .. name
        end
    end
end

-- 返回模块
return WoofUIModule
