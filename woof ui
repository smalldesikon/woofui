        end)
        
        addBtn.MouseButton1Click:Connect(function()
            local value = library.flags[flagName].State
            value = math.clamp(value + 1, min, max)
            library.flags[flagName]:SetValue(value)
        end)
        
        -- 设置初始值
        library.flags[flagName]:SetValue(default)
        
        -- 滑块拖拽
        local dragging = false
        local function updateSliderFromInput(input)
            local pos = input.Position
            local percent = (pos.X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X
            percent = math.clamp(percent, 0, 1)
            local newValue = min + (max - min) * percent
            library.flags[flagName]:SetValue(newValue)
        end
        
        sliderBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                updateSliderFromInput(input)
                dragging = true
            end
        end)
        
        b.UserInputService.InputEnded:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                dragging = false
            end
        end)
        
        b.UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                updateSliderFromInput(input)
            end
        end)
        
        -- 文本框输入
        local typing = false
        valueBox.Focused:Connect(function()
            typing = true
        end)
        
        valueBox.FocusLost:Connect(function()
            typing = false
            if valueBox.Text == "" then
                library.flags[flagName]:SetValue(default)
            end
        end)
        
        valueBox:GetPropertyChangedSignal("Text"):Connect(function()
            if not typing then return end
            valueBox.Text = valueBox.Text:gsub("%D+", "")
            local text = valueBox.Text
            if text ~= "" and tonumber(text) then
                library.flags[flagName]:SetValue(tonumber(text))
            end
        end)
        
        addButtonFeedback(sliderBtn, dp(52, 62, 72))
        addButtonFeedback(addBtn, dp(255, 255, 255))
        addButtonFeedback(minusBtn, dp(255, 255, 255))
        
        return {
            Set = function(value)
                library.flags[flagName]:SetValue(value)
            end,
            Get = function()
                return library.flags[flagName].State
            end
        }
    end

    function tabMethods:Dropdown(config)
