                corner.Parent = btn
                btn.MouseButton1Click:Connect(function()
                    dropdownText.PlaceholderText = optName
                    dropdownText.Text = ""
                    library.flags[flagName].State = optName
                    callback(optName)
                    if isOpen then
                        toggleDropdown()
                    end
                end)
                addButtonFeedback(btn, dp(58, 69, 80))
            end,
            RemoveOption = function(self, optName)
